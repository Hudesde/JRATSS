@startuml cap3_flujo_voz_parte1_stt

title Sistema Botas - Parte 1: Speech-to-Text (STT)

skinparam rectangle {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontSize 12
}

skinparam note {
    BackgroundColor #FFF9C4
    BorderColor #F57C00
}

' Capa 1: STT (Speech-to-Text)
rectangle "**CAPA 1: SPEECH-TO-TEXT (STT)**" as stt #C8E6C9 {
    rectangle "Micrófono del Usuario" as mic #E8F5E9
    rectangle "SoX Audio Recorder\n(record_audio)" as sox #C8E6C9
    rectangle "OpenAI Whisper API\n(transcribe)" as whisper #A5D6A7
    rectangle "Texto Transcrito" as text1 #E8F5E9
    
    mic -down-> sox: Captura audio\n(WAV format)
    sox -down-> whisper: Envía archivo WAV\n(API Request)
    whisper -down-> text1: Retorna texto:\n"Crea carpeta proyectos"
}

note right of whisper
  **Modelo:** whisper-1
  **Formato:** WAV
  **Idioma:** español
  **Timeout:** 30s
  **Precisión:** ~95%
end note

' Interfaz Gráfica
rectangle "**GUI Perl/Tk**" as gui #B3E5FC {
    [🎤 Botón Grabar]
    [📝 Área Transcripción]
}

gui -right-> mic: Click usuario\ninicia grabación
text1 -left-> gui: Muestra\ntranscripción

note bottom
  **Tiempo STT:** 2-5 segundos
  - Grabación: variable (usuario)
  - Upload: <1 seg
  - Procesamiento Whisper: 1-4 seg
end note

@enduml
