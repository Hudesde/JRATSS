@startuml metodos_aprendizaje_ia

title Métodos de Aprendizaje en Inteligencia Artificial

skinparam rectangle {
    BackgroundColor #E3F2FD
    BorderColor #1976D2
    FontSize 11
    FontStyle bold
}

skinparam defaultTextAlignment center

' Disposición vertical compacta - 5 bloques
rectangle "1. APRENDIZAJE SUPERVISADO\n\nDatos etiquetados (X, y) conocidos\nEjemplos: Clasificación, Regresión\nAlgoritmos: SVM, Random Forest, Neural Nets\nVentaja: Alta precisión\nDesventaja: Requiere etiquetado manual" as SUP #C8E6C9

rectangle "2. APRENDIZAJE NO SUPERVISADO\n\nSin etiquetas, descubre patrones ocultos\nEjemplos: Clustering, Reducción dimensional\nAlgoritmos: K-means, DBSCAN, PCA\nVentaja: No requiere etiquetado\nDesventaja: Resultados difíciles de evaluar" as UNSUP #FFE082

rectangle "3. APRENDIZAJE POR REFUERZO\n\nAgente aprende mediante recompensas\nEjemplos: AlphaGo, Robótica, Videojuegos\nAlgoritmos: Q-Learning, PPO, DQN\nVentaja: Adaptación dinámica\nDesventaja: Requiere simulación/entorno" as RL #FFCCBC

rectangle "4. APRENDIZAJE SEMI-SUPERVISADO\n\nCombina datos etiquetados + no etiquetados\nEjemplos: Transcripción, OCR con datos limitados\nAlgoritmos: Self-training, Co-training\nVentaja: Reduce costo de etiquetado\nDesventaja: Puede propagar errores" as SEMI #E1BEE7

rectangle "5. APRENDIZAJE AUTO-SUPERVISADO\n\nAutogeneración de tareas supervisadas\nEjemplos: BERT (masked tokens), GPT (next token)\nAlgoritmos: Transformers, Contrastive Learning\nVentaja: Escala masiva sin etiquetas\nDesventaja: Requiere gran capacidad computacional" as SELF #B2DFDB

' Flujo vertical
SUP -down-> UNSUP
UNSUP -down-> RL
RL -down-> SEMI
SEMI -down-> SELF

' Leyenda compacta
legend bottom right
  |= Color |= Método |
  |<#C8E6C9> | Supervisado |
  |<#FFE082> | No Supervisado |
  |<#FFCCBC> | Refuerzo |
  |<#E1BEE7> | Semi-supervisado |
  |<#B2DFDB> | Auto-supervisado |
endlegend

@enduml
